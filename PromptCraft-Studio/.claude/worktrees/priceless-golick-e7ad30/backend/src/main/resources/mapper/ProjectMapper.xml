<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.promptcraft.mapper.ProjectMapper">

    <resultMap id="ProjectVOMap" type="com.promptcraft.vo.ProjectVO">
        <id     property="id"              column="id"/>
        <result property="name"            column="name"/>
        <result property="description"     column="description"/>
        <result property="tags"            column="tags"/>
        <result property="stableVersionId" column="stable_version_id"/>
        <result property="createdAt"       column="created_at"/>
        <result property="updatedAt"       column="updated_at"/>
        <result property="versionCount"    column="version_count"/>
        <result property="stableVersionNo" column="stable_version_no"/>
    </resultMap>

    <select id="selectProjectList" resultMap="ProjectVOMap">
        SELECT
            p.id,
            p.name,
            p.description,
            p.tags,
            p.stable_version_id,
            p.created_at,
            p.updated_at,
            COUNT(pv.id)  AS version_count,
            sv.version_no AS stable_version_no
        FROM project p
        LEFT JOIN prompt_version pv ON pv.project_id = p.id
        LEFT JOIN prompt_version sv ON sv.id = p.stable_version_id
        <where>
            <if test="keyword != null and keyword != ''">
                AND (p.name LIKE #{keyword} OR p.description LIKE #{keyword})
            </if>
            <if test="tagsFilter != null and tagsFilter != ''">
                AND p.tags IS NOT NULL
                AND JSON_CONTAINS(p.tags, #{tagsFilter})
            </if>
        </where>
        GROUP BY p.id, p.name, p.description, p.tags,
                 p.stable_version_id, p.created_at, p.updated_at, sv.version_no
        ORDER BY p.updated_at DESC
    </select>

</mapper>
