# 本地配置模板 — 复制为 application-local.yml 并填写真实值
# 此文件已被 .gitignore 排除，不会提交到仓库

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/promptcraft?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: root
    password: your_mysql_password
    driver-class-name: com.mysql.cj.jdbc.Driver

promptcraft:
  # 用于 AES-256-GCM 加密存储 API Key，长度须 >= 16 字符，建议 32 字符随机串
  # 生成示例（Linux/macOS）：openssl rand -hex 32
  # 生成示例（PowerShell）：   -join ((65..90)+(97..122)+(48..57) | Get-Random -Count 32 | % {[char]$_})
  app-secret: change_me_to_a_32char_random_string

  cors:
    # 前端开发服务器地址，生产部署时改为实际域名
    allowed-origins:
      - http://localhost:5173
